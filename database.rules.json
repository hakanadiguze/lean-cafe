{
  "rules": {
    "lc": {
      "sessions": {
        "$sessionId": {
          ".read": true,
          ".write": "auth != null || data.exists()",
          "phase":   { ".write": "root.child('lc/sessions/'+$sessionId+'/adminUid').val() === (auth != null ? auth.uid : null) || data.parent().child('isGuestAdmin').val() === true" },
          "timers":  { ".write": true },
          "rooms":   { ".write": true },
          "cards":   { "$cardId": { ".write": true } },
          "participants": { "$uid": { ".write": true } },
          "roomData": { ".write": true },
          "closed":  { ".write": true }
        }
      },
      "admins": {
        "$uid": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    }
  }
}
