{
  "rules": {
    "lean-cafe": {
      "sessions": {
        "$sessionId": {
          // Anyone with the session ID can read (participants join via link)
          ".read": true,

          // Only authenticated users (facilitators) can create sessions
          ".write": "auth != null || data.exists()",

          "phase":         { ".write": "auth != null && auth.uid === data.parent().child('adminUid').val()" },
          "timers":        { ".write": "auth != null && auth.uid === data.parent().child('adminUid').val()" },
          "rooms":         { ".write": "auth != null && auth.uid === data.parent().child('adminUid').val()" },

          "cards": {
            "$cardId": {
              // Anyone can add cards; only card owner or admin can delete
              ".write": true
            }
          },

          "participants": {
            "$uid": {
              // Anyone can register themselves as a participant
              ".write": true
            }
          },

          "roomData": {
            // Anyone in the session can write room data (Scribe)
            ".write": true
          }
        }
      }
    }
  }
}
